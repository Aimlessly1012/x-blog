# NextAuth 配置
# 应用访问 URL（生产环境改为你的域名）
NEXTAUTH_URL=http://localhost:3001

# NextAuth 密钥（使用 openssl rand -base64 32 生成）
NEXTAUTH_SECRET=your-secret-key-here

# GitHub OAuth 配置
# 在 https://github.com/settings/developers 创建 OAuth App
# Authorization callback URL: http://your-domain/api/auth/callback/github
GITHUB_ID=your-github-client-id
GITHUB_SECRET=your-github-client-secret

# 管理员 GitHub ID（数字 ID，不是用户名）
# 访问 https://api.github.com/users/your-username 获取
ADMIN_GITHUB_ID=your-github-user-id

# 可选配置
# NODE_ENV=production
